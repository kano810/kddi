{
  "article-cf-list": {
    "title": "Article CF List（記事・事例一覧）",
    "description": "記事API または 事例API で取得した一覧を表示します。API オリジン・パスを指定しない場合は同一オリジンの記事APIを使用します。",
    "properties": {
      "api-origin": {
        "title": "API オリジン（ドメイン）",
        "description": "AEM のベース URL。未指定時は同一オリジン。事例API利用時は例: https://biz.kddi.com",
        "type": "string"
      },
      "api-path": {
        "title": "API パス",
        "description": "API のパス。未指定時は /bin/articleindex.json。事例APIは /bin/kddi-com/casestudyindex.json",
        "type": "string"
      },
      "ck-lang": {
        "title": "言語",
        "description": "ck_lang（例: ja, en）",
        "type": "string"
      },
      "ck-limit": {
        "title": "表示件数",
        "description": "ck_limit（最大 1000）",
        "type": "number",
        "default": 10
      },
      "ck-offset": {
        "title": "オフセット",
        "description": "ck_offset",
        "type": "number"
      },
      "ck-article-site": {
        "title": "サイト（記事API）",
        "description": "ck_article-site",
        "type": "string"
      },
      "ck-root-path": {
        "title": "ルートパス（事例API）",
        "description": "ck_rootPath。事例API利用時は例: /content/kddi-com/usecase",
        "type": "string"
      },
      "ck-industry": {
        "title": "業種フィルタ",
        "description": "ck_industry（カンマ区切り）",
        "type": "string"
      },
      "ck-category": {
        "title": "カテゴリフィルタ",
        "description": "ck_category（カンマ区切り）",
        "type": "string"
      },
      "layout": {
        "title": "レイアウト",
        "description": "表示形式",
        "type": "string",
        "enum": ["cards", "list"],
        "default": "cards"
      }
    }
  }
}
